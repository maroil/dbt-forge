---
const target = 'https://github.com/maroil/dbt-forge';
import SeoHead from '../components/SeoHead.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <SeoHead
      title="Redirecting to GitHub"
      description="Redirect to the dbt-forge GitHub repository."
      path="/github/"
      robots="noindex,follow"
    />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
  </head>
  <body>
    <p>Redirecting to <a href={target}>GitHub</a>…</p>
  </body>
</html>
