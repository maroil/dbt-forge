---
import '../styles/site.css';

const repoUrl = 'https://github.com/maroil/dbt-forge';
const issuesUrl = `${repoUrl}/issues`;

const adapters = ['BigQuery', 'Snowflake', 'PostgreSQL', 'DuckDB', 'Databricks', 'Redshift', 'Trino', 'Spark'];

const features = [
  {
    eyebrow: 'Why it exists',
    title: 'Stop rebuilding the same dbt project setup.',
    body: 'Use one command to scaffold folders, profiles, packages, and optional setup files that teams often add by hand.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>`
  },
  {
    eyebrow: 'What it generates',
    title: 'Start with a structure that matches dbt work.',
    body: 'The scaffold includes staging, intermediate, marts, tests, macros, and adapter-aware profile files for the warehouse you selected.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>`
  },
  {
    eyebrow: 'How it grows',
    title: 'Extend an existing dbt project without overwriting files.',
    body: 'Use `dbt-forge add mart` and `dbt-forge add source` when the project expands into new domains or source systems.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>`
  },
];

const workflow = [
  {
    step: '01',
    label: 'Install',
    command: 'uv tool install dbt-forge',
    body: 'Install the CLI.',
  },
  {
    step: '02',
    label: 'Initialize',
    command: 'dbt-forge init analytics_core --defaults',
    body: 'Scaffold a new dbt project.',
  },
  {
    step: '03',
    label: 'Grow',
    command: 'dbt-forge add mart finance',
    body: 'Scaffold a new mart later.',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>dbt-forge | Scaffold dbt projects with a consistent starting structure</title>
    <meta
      name="description"
      content="dbt-forge is a Python CLI for scaffolding dbt projects with a consistent starting structure, adapter-aware profiles, and optional setup files for common team workflows."
    />
  </head>
  <body class="forge-home">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <nav class="nav">
      <a href="/" class="logo"><span class="logo-icon">⬡</span> dbt-forge</a>
      <div class="nav-links">
        <a href="/docs/">Docs</a>
        <a href="/docs/getting-started/">Quickstart</a>
        <a href="/docs/cli/init/">CLI</a>
        <a href={repoUrl}>GitHub</a>
      </div>
      <div class="nav-actions">
        <a href={issuesUrl} class="nav-btn nav-btn-outline">Issues</a>
        <a href="/docs/getting-started/" class="nav-btn nav-btn-primary">Get Started</a>
      </div>
    </nav>

    <main class="container">
      <section class="hero">
        <div class="hero-badge">Python CLI for dbt projects</div>
        <h1>Scaffold a dbt project<br><span class="highlight">with a consistent starting structure.</span></h1>
        <p class="subtitle"><code>dbt-forge</code> is for teams that want a working dbt project without rebuilding the same folders, profiles, starter models, and setup files for every new project.</p>

        <div class="terminal-glass">
          <div class="term-header">
            <div class="term-dots">
              <div class="dot red"></div>
              <div class="dot yellow"></div>
              <div class="dot green"></div>
            </div>
            <div class="term-title">marouane@macbook: ~/projects</div>
          </div>
          <div class="term-body">
            <div><span class="prompt">❯</span> <span class="command">dbt-forge init analytics_core</span> <span class="flag">--defaults</span></div>
            <div><span class="prompt">❯</span> <span class="command">cd analytics_core</span></div>
            <div><span class="prompt">❯</span> <span class="command">uv sync</span></div>
            <div><span class="prompt">❯</span> <span class="command">uv run --env-file .env dbt debug</span></div>
            <div><span class="prompt">❯</span> <span class="cursor"></span></div>
          </div>
        </div>

        <div class="hero-adapters">
          <span class="adapters-label">Adapter templates</span>
          <div class="adapters-list">
            {adapters.map((adapter) => <span>{adapter}</span>)}
          </div>
        </div>
      </section>

      <section class="workflow-section">
        <div class="workflow-header">
          <span class="workflow-kicker">Why teams use it</span>
          <h2>Avoid hand-built setup and inconsistent dbt project layouts.</h2>
          <p><code>dbt-forge</code> gives you a narrow starting point: a dbt project structure, adapter-aware profiles, starter models, and optional tooling that can be reused across projects.</p>
        </div>

        <div class="cards">
          {features.map((feature) => (
            <article class="glass-card feature-card">
              <div class="icon-wrap" set:html={feature.icon}></div>
              <span class="card-eyebrow">{feature.eyebrow}</span>
              <h3>{feature.title}</h3>
              <p>{feature.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="workflow-section">
        <div class="workflow-header">
          <span class="workflow-kicker">Supported workflows</span>
          <h2>Use prompts when exploring, or defaults when you need repeatable output.</h2>
        </div>

        <div class="cards workflow-cards">
          {workflow.map((item) => (
            <article class="glass-card workflow-card">
              <span class="step-num">{item.step}</span>
              <h3>{item.label}</h3>
              <code class="command-box">{item.command}</code>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </section>
    </main>
  </body>
</html>
