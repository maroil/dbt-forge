---
import '../styles/site.css';
import SeoHead from '../components/SeoHead.astro';

const repoUrl = 'https://github.com/maroil/dbt-forge';
const issuesUrl = `${repoUrl}/issues`;
const siteUrl = 'https://dbt-forge.marou.one';
const pageTitle = 'dbt Project Scaffold and Template CLI for Teams';
const pageDescription =
  'dbt-forge is a Python CLI for dbt project scaffolding, project templates, SQL-to-dbt migration, health checks, and team standards.';

const adapters = ['BigQuery', 'Snowflake', 'PostgreSQL', 'DuckDB', 'Databricks', 'Redshift', 'Trino', 'Spark'];

const features = [
  {
    eyebrow: 'Why it exists',
    title: 'Stop rebuilding the same dbt project setup.',
    body: 'Use one command to scaffold folders, profiles, packages, pre-commit hooks, CI pipelines, and environment config that teams often add by hand.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>`
  },
  {
    eyebrow: 'What it generates',
    title: 'Start with a structure that matches dbt work.',
    body: 'The scaffold includes staging, intermediate, marts, tests, macros, adapter-aware profiles, and optional tooling like SQLFluff, pre-commit, and CI pipelines. Use --mesh for multi-project setups with access controls and contracts.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>`
  },
  {
    eyebrow: 'How it grows',
    title: 'Migrate SQL, introspect warehouses, generate docs, and add components.',
    body: 'Use `migrate` to convert legacy SQL to dbt. Use `add source --from-database` to scaffold from real warehouse metadata. Use `docs generate` for AI-assisted documentation. Run `doctor` to validate best practices.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>`
  },
];

const workflow = [
  {
    step: '01',
    label: 'Scaffold',
    command: 'dbt-forge init analytics_core --defaults',
    body: 'Scaffold a single project or a multi-project Mesh with --mesh.',
  },
  {
    step: '02',
    label: 'Migrate',
    command: 'dbt-forge migrate ./legacy_sql/',
    body: 'Convert existing SQL scripts into dbt models with ref() and source().',
  },
  {
    step: '03',
    label: 'Introspect',
    command: 'dbt-forge add source raw --from-database',
    body: 'Generate sources and staging models from live warehouse metadata.',
  },
  {
    step: '04',
    label: 'Extend',
    command: 'dbt-forge add model users',
    body: 'Add models, tests, packages, CI, and sub-projects as the project grows.',
  },
  {
    step: '05',
    label: 'Document',
    command: 'dbt-forge docs generate',
    body: 'Generate model and column descriptions using Claude, OpenAI, or Ollama.',
  },
  {
    step: '06',
    label: 'Maintain',
    command: 'dbt-forge doctor && dbt-forge status',
    body: 'Validate best practices and review project health.',
  },
];

const guideLinks = [
  {
    title: 'dbt project template',
    href: '/docs/guides/dbt-project-template/',
    body: 'What a practical dbt template should include and how dbt-forge scaffolds it.',
  },
  {
    title: 'How to scaffold a dbt project',
    href: '/docs/guides/how-to-scaffold-a-dbt-project/',
    body: 'The shortest path from installation to a repeatable dbt project scaffold.',
  },
  {
    title: 'Migrate SQL to dbt',
    href: '/docs/guides/migrate-sql-to-dbt/',
    body: 'Turn legacy SQL scripts into dbt models with ref() and source().',
  },
  {
    title: 'dbt project best practices',
    href: '/docs/guides/dbt-project-best-practices/',
    body: 'Structure, naming, tests, packages, and health checks for maintainable dbt projects.',
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'dbt-forge',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'macOS, Linux, Windows',
    description: pageDescription,
    url: siteUrl,
    softwareVersion: '0.4.x',
    codeRepository: repoUrl,
    keywords: [
      'dbt project scaffold',
      'dbt project template',
      'migrate SQL to dbt',
      'dbt CLI',
      'dbt mesh setup',
    ],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <SeoHead
      title={pageTitle}
      description={pageDescription}
      path="/"
      jsonLd={jsonLd}
    />
  </head>
  <body class="forge-home">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <nav class="nav">
      <a href="/" class="logo"><span class="logo-icon">⬡</span> dbt-forge</a>
      <div class="nav-links">
        <a href="/docs/">Docs</a>
        <a href="/docs/getting-started/">Quickstart</a>
        <a href="/docs/cli/init/">CLI</a>
        <a href={repoUrl}>GitHub</a>
      </div>
      <div class="nav-actions">
        <a href={issuesUrl} class="nav-btn nav-btn-outline">Issues</a>
        <a href="/docs/getting-started/" class="nav-btn nav-btn-primary">Get Started</a>
      </div>
    </nav>

    <main class="container">
      <section class="hero">
        <div class="hero-badge">dbt project scaffold CLI</div>
        <h1>Scaffold a dbt project<br><span class="highlight">with a repeatable template for teams.</span></h1>
        <p class="subtitle"><code>dbt-forge</code> is a Python CLI for dbt project scaffolding, dbt project templates, SQL-to-dbt migration, and health checks. It helps teams start faster without rebuilding the same folders, profiles, starter models, and setup files for every new project.</p>

        <div class="terminal-glass">
          <div class="term-header">
            <div class="term-dots">
              <div class="dot red"></div>
              <div class="dot yellow"></div>
              <div class="dot green"></div>
            </div>
            <div class="term-title">marouane@macbook: ~/projects</div>
          </div>
          <div class="term-body">
            <div><span class="prompt">❯</span> <span class="command">dbt-forge init analytics_core</span> <span class="flag">--defaults</span></div>
            <div><span class="prompt">❯</span> <span class="command">cd analytics_core</span></div>
            <div><span class="prompt">❯</span> <span class="command">uv sync</span></div>
            <div><span class="prompt">❯</span> <span class="command">uv run --env-file .env dbt debug</span></div>
            <div><span class="prompt">❯</span> <span class="cursor"></span></div>
          </div>
        </div>

        <div class="hero-adapters">
          <span class="adapters-label">Adapter templates</span>
          <div class="adapters-list">
            {adapters.map((adapter) => <span>{adapter}</span>)}
          </div>
        </div>
      </section>

      <section class="workflow-section">
        <div class="workflow-header">
          <span class="workflow-kicker">Why teams use it</span>
          <h2>Avoid hand-built setup and inconsistent dbt project layouts.</h2>
          <p><code>dbt-forge</code> gives you a repeatable dbt project scaffold with adapter-aware profiles, starter models, a clear project structure, and optional tooling that can be reused across projects.</p>
        </div>

        <div class="cards">
          {features.map((feature) => (
            <article class="glass-card feature-card">
              <div class="icon-wrap" set:html={feature.icon}></div>
              <span class="card-eyebrow">{feature.eyebrow}</span>
              <h3>{feature.title}</h3>
              <p>{feature.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="workflow-section">
        <div class="workflow-header">
          <span class="workflow-kicker">Supported workflows</span>
          <h2>From first scaffold to multi-project meshes, migration, and AI docs.</h2>
          <p>Use the same CLI to initialize a dbt project, migrate legacy SQL to dbt, introspect warehouse metadata, validate best practices, and keep templates updated over time.</p>
        </div>

        <div class="cards workflow-cards">
          {workflow.map((item) => (
            <article class="glass-card workflow-card">
              <span class="step-num">{item.step}</span>
              <h3>{item.label}</h3>
              <code class="command-box">{item.command}</code>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="workflow-section">
        <div class="workflow-header">
          <span class="workflow-kicker">Keep reading</span>
          <h2>Go deeper in the docs without bloating the homepage.</h2>
          <p>
            Start with <a href="/docs/getting-started/">Getting started</a>, then use
            {' '}<a href="/docs/cli/init/">init</a>, <a href="/docs/cli/add/">add</a>,
            {' '}<a href="/docs/cli/migrate/">migrate</a>, and <a href="/docs/cli/doctor/">doctor</a>
            {' '}to build and maintain a project. The more detailed guides live in the docs.
          </p>
        </div>

        <div class="cards guide-cards">
          {guideLinks.map((guide) => (
            <article class="glass-card guide-card link-card">
              <h3><a href={guide.href}>{guide.title}</a></h3>
              <p>{guide.body}</p>
            </article>
          ))}
        </div>
      </section>
    </main>
  </body>
</html>
