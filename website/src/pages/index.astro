---
import '../styles/site.css';

const repoUrl = 'https://github.com/maroil/dbt-forge';
const issuesUrl = `${repoUrl}/issues`;

const adapters = ['BigQuery', 'Snowflake', 'PostgreSQL', 'DuckDB', 'Databricks', 'Redshift', 'Trino', 'Spark'];

const features = [
  {
    eyebrow: 'Scaffold',
    title: 'Start from a repo that already makes sense.',
    body: 'Profiles, folders, and starter structure are generated for you.',
  },
  {
    eyebrow: 'Standardize',
    title: 'Keep conventions stable from day one.',
    body: 'Use prompts when exploring or defaults when teams need repeatable output.',
  },
  {
    eyebrow: 'Extend',
    title: 'Grow the project without drift.',
    body: 'Add marts and sources later without reworking the repo shape.',
  },
];

const terminalSteps = [
  '$ dbt-forge init analytics_core --defaults',
  '? Which adapter should your project use? snowflake',
  '? Include starter marts and staging structure? yes',
  'Created analytics_core with adapter-aware profiles and starter folders.',
];

const heroHighlights = [
  { value: '08', label: 'supported adapters' },
  { value: '01', label: 'clean baseline' },
  { value: '00', label: 'hosted services' },
];

const workflow = [
  {
    step: '01',
    label: 'Install',
    command: 'uv tool install dbt-forge',
    body: 'Install once.',
  },
  {
    step: '02',
    label: 'Initialize',
    command: 'dbt-forge init analytics_core --defaults',
    body: 'Generate the baseline.',
  },
  {
    step: '03',
    label: 'Grow',
    command: 'dbt-forge add mart finance',
    body: 'Extend without drift.',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>dbt-forge | Dark-first dbt scaffolding</title>
    <meta
      name="description"
      content="dbt-forge is a Python CLI for scaffolding production-ready dbt projects with opinionated defaults, warehouse-aware templates, and a clean team standard from day one."
    />
  </head>
  <body class="forge-home">
    <div class="forge-shell">
      <div class="forge-glow forge-glow-left" aria-hidden="true"></div>
      <div class="forge-glow forge-glow-right" aria-hidden="true"></div>
      <div class="forge-lines" aria-hidden="true"></div>

      <header class="forge-topbar">
        <div class="forge-topbar-inner">
          <a class="forge-brand" href="/">
            <span class="forge-brand-mark">df</span>
            <span class="forge-brand-copy">
              <strong>dbt-forge</strong>
              <span>Opinionated scaffolding for analytics engineering teams.</span>
            </span>
          </a>

          <nav class="forge-nav" aria-label="Primary">
            <a href="/docs/">Docs</a>
            <a href="/docs/getting-started/">Quickstart</a>
            <a href="/docs/cli/init/">CLI</a>
            <a href={repoUrl}>GitHub</a>
          </nav>

          <div class="forge-topbar-actions">
            <a class="forge-topbar-pill" href={issuesUrl}>Issues</a>
            <a class="forge-topbar-button" href="/docs/getting-started/">Get started</a>
          </div>
        </div>
      </header>

      <main class="forge-main">
        <section class="forge-hero-shell">
          <div class="forge-hero">
            <div class="forge-hero-copy">
              <span class="forge-eyebrow">Python CLI · open source · dark-first docs</span>
              <h1>
                <span class="forge-hero-line">Start with a dbt repo</span>
                <span class="forge-hero-line forge-hero-line-accent">that already feels</span>
                <span class="forge-hero-line forge-hero-line-accent-secondary">like team standard.</span>
              </h1>
              <p class="forge-hero-body">
                <code>dbt-forge</code> scaffolds dbt projects with sensible defaults, adapter-aware
                profiles, and a structure teams can keep.
              </p>

              <div class="forge-cta-row">
                <a class="forge-button forge-button-primary" href="/docs/getting-started/">
                  Documentation
                </a>
                <a class="forge-button forge-button-secondary" href={repoUrl}>GitHub</a>
              </div>

              <div class="forge-command-bar" aria-label="CLI command">
                <code>dbt-forge init analytics_core --defaults</code>
                <span>CLI</span>
              </div>
            </div>

            <div class="forge-hero-aside">
              <div class="forge-terminal-preview" aria-label="Terminal preview">
                <div class="forge-terminal-preview-bar">
                  <span></span>
                  <span></span>
                  <span></span>
                </div>
                <div class="forge-terminal-preview-body">
                  {terminalSteps.map((line) => <code>{line}</code>)}
                </div>
              </div>

              <div class="forge-hero-highlights">
                {heroHighlights.map((item) => (
                  <article class="forge-hero-highlight">
                    <strong>{item.value}</strong>
                    <span>{item.label}</span>
                  </article>
                ))}
              </div>
            </div>
          </div>

          <div class="forge-proof-row" aria-label="Supported adapters">
            <span>Supported adapters</span>
            <div class="forge-proof-list">
              {adapters.map((adapter) => <span>{adapter}</span>)}
            </div>
          </div>
        </section>

        <section class="forge-feature-grid">
          {features.map((feature) => (
            <article class="forge-feature-card">
              <span>{feature.eyebrow}</span>
              <h2>{feature.title}</h2>
              <p>{feature.body}</p>
            </article>
          ))}
        </section>

        <section class="forge-band">
          <div class="forge-band-copy">
            <span class="forge-section-kicker">Three steps</span>
            <h2>Install it, scaffold once, and keep moving.</h2>
          </div>

          <div class="forge-band-grid">
            {workflow.map((item) => (
              <article class="forge-command-card">
                <span class="forge-command-step">{item.step}</span>
                <strong>{item.label}</strong>
                <code>{item.command}</code>
                <p>{item.body}</p>
              </article>
            ))}
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
