unit_tests:
  - name: test_stg_example_source__orders_renames_and_converts
    description: >
      Verifies that the staging model renames columns correctly
      and converts amounts from cents to dollars.
    model: stg_example_source__orders
    given:
      - input: source('example_source', 'orders')
        rows:
          - {id: 1, customer_id: 100, amount: 10000, status: 'Completed', created_at: '2024-01-15'}
          - {id: 2, customer_id: 101, amount: 0, status: 'Pending', created_at: '2024-01-16'}
          - {id: 3, customer_id: 102, amount: 25050, status: 'Completed', created_at: '2024-01-17'}
    expect:
      rows:
        - {order_id: 1, customer_id: 100, amount_usd: 100.00, status: 'completed', created_at: '2024-01-15'}
        - {order_id: 2, customer_id: 101, amount_usd: 0.00, status: 'pending', created_at: '2024-01-16'}
        - {order_id: 3, customer_id: 102, amount_usd: 250.50, status: 'completed', created_at: '2024-01-17'}
