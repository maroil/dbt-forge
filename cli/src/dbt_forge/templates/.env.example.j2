# dbt-forge generated .env.example
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: tells dbt where to find profiles.yml
DBT_PROFILES_DIR=./profiles

{% if adapter_key == "bigquery" %}
# BigQuery: uses Application Default Credentials (ADC)
# Run: gcloud auth application-default login
# Or set a service account key:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project
{% elif adapter_key == "snowflake" %}
# Snowflake credentials
DBT_ACCOUNT=your_account.region
DBT_USER=your_user
DBT_PASSWORD=your_password
DBT_ROLE=your_role
DBT_WAREHOUSE=your_warehouse
DBT_DATABASE=your_database
{% elif adapter_key == "postgresql" %}
# PostgreSQL credentials
DBT_HOST=localhost
DBT_PORT=5432
DBT_USER=your_user
DBT_PASSWORD=your_password
DBT_DATABASE=your_database
{% elif adapter_key == "duckdb" %}
# DuckDB: no credentials needed — runs locally
# DBT_DATABASE=./{{ project_name }}.duckdb
{% elif adapter_key == "databricks" %}
# Databricks credentials
DBT_HOST=your-workspace.cloud.databricks.com
DBT_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id
DBT_TOKEN=your_databricks_token
DBT_CATALOG=your_catalog
{% elif adapter_key == "redshift" %}
# Redshift credentials
DBT_HOST=your-cluster.us-east-1.redshift.amazonaws.com
DBT_PORT=5439
DBT_USER=your_user
DBT_PASSWORD=your_password
DBT_DATABASE=your_database
{% elif adapter_key == "trino" %}
# Trino credentials
DBT_HOST=your-trino-coordinator.example.com
DBT_PORT=8443
DBT_USER=your_user
DBT_PASSWORD=your_password
DBT_DATABASE=your_catalog
{% elif adapter_key == "spark" %}
# Spark credentials
DBT_HOST=your-spark-master.example.com
DBT_PORT=10000
DBT_USER=your_user
DBT_SCHEMA=your_schema
{% endif %}
