with

source as (

    select * from {{ '{{' }} source('example_source', 'orders') {{ '}}' }}

),

renamed as (

    select
        id                              as order_id,
        customer_id,
        lower(status)                   as status,
        amount / 100.0                  as amount_usd,
        created_at

    from source

)

select * from renamed
