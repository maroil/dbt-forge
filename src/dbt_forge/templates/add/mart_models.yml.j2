version: 2

models:
  - name: {{ mart }}_orders
    description: "Orders model for the {{ mart }} mart"
    config:
      materialized: table
      tags:
        - {{ mart }}
    columns:
      - name: order_id
        description: "Primary key — unique order identifier"
        data_tests:
          - unique
          - not_null
      - name: amount
        description: "Order total amount"
        data_tests:
          - not_null
      - name: status
        description: "Order status"
      - name: order_date
        description: "Date the order was placed"
