unit_tests:
  - name: test_stg_example_source__orders_positive_amount
    description: >
      Verifies that the staging model correctly passes through orders
      and that amounts remain non-negative.
    model: stg_example_source__orders
    given:
      - input: source('example_source', 'orders')
        rows:
          - {id: 1, amount: 100.00, status: 'completed', created_at: '2024-01-15'}
          - {id: 2, amount: 0.00, status: 'pending', created_at: '2024-01-16'}
          - {id: 3, amount: 250.50, status: 'completed', created_at: '2024-01-17'}
    expect:
      rows:
        - {order_id: 1, amount: 100.00, status: 'completed'}
        - {order_id: 2, amount: 0.00, status: 'pending'}
        - {order_id: 3, amount: 250.50, status: 'completed'}
